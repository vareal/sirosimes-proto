        }
      },
      "description": "CancelExecutionResponse is the response after cancelling an execution."
    },
    "v1Execution": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UUID format)."
        },
        "workflowId": {
          "type": "string",
          "description": "Workflow that was executed."
        },
        "versionId": {
          "type": "string",
          "description": "Specific version that was executed."
        },
        "status": {
          "$ref": "#/definitions/v1ExecutionStatus",
          "description": "Current execution status."
        },
        "input": {
          "type": "object",
          "description": "Input data provided to the workflow."
        },
        "output": {
          "type": "object",
          "description": "Output data produced by the workflow."
        },
        "error": {
          "type": "string",
          "description": "Error details if the execution failed."
        },
        "triggeredBy": {
          "type": "string",
          "description": "Actor ID or trigger ID that initiated this execution."
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "Execution represents a single run of a workflow."
    },
    "v1ExecutionStatus": {
      "type": "string",
      "enum": [
        "EXECUTION_STATUS_UNSPECIFIED",
        "EXECUTION_STATUS_PENDING",
        "EXECUTION_STATUS_RUNNING",
        "EXECUTION_STATUS_COMPLETED",
        "EXECUTION_STATUS_FAILED",
        "EXECUTION_STATUS_CANCELLED",
        "EXECUTION_STATUS_PAUSED"
      ],
      "default": "EXECUTION_STATUS_UNSPECIFIED",
      "description": "ExecutionStatus represents the lifecycle state of a workflow execution.\n\n - EXECUTION_STATUS_PENDING: Execution is queued and waiting to start.\n - EXECUTION_STATUS_RUNNING: Execution is actively running.\n - EXECUTION_STATUS_COMPLETED: Execution completed successfully.\n - EXECUTION_STATUS_FAILED: Execution failed with an error.\n - EXECUTION_STATUS_CANCELLED: Execution was cancelled by a user or system.\n - EXECUTION_STATUS_PAUSED: Execution is paused (e.g., waiting for approval)."
    },
    "v1ExecutionStep": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UUID format)."
        },
        "executionId": {
          "type": "string",
          "description": "Parent execution ID."
        },
        "stepName": {
          "type": "string",
          "description": "Name of this step as defined in the workflow DSL."
        },
        "stepType": {
          "type": "string",
          "description": "Type of step (e.g., \"llm\", \"http\", \"transform\", \"approval\")."
        },
        "status": {
          "$ref": "#/definitions/v1ExecutionStepStatus",
          "description": "Current step status."
        },
        "input": {
          "type": "object",
          "description": "Input data provided to this step."
        },
        "output": {
          "type": "object",
          "description": "Output data produced by this step."
        },
        "error": {
          "type": "string",
          "description": "Error details if the step failed."
        },
        "retries": {
          "type": "integer",
          "format": "int32",
          "description": "Number of retry attempts performed."
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "ExecutionStep represents a single step within a workflow execution."
    },
    "v1ExecutionStepStatus": {
      "type": "string",
      "enum": [
        "EXECUTION_STEP_STATUS_UNSPECIFIED",
        "EXECUTION_STEP_STATUS_PENDING",
        "EXECUTION_STEP_STATUS_RUNNING",
        "EXECUTION_STEP_STATUS_COMPLETED",
        "EXECUTION_STEP_STATUS_FAILED",
        "EXECUTION_STEP_STATUS_SKIPPED",
        "EXECUTION_STEP_STATUS_WAITING"
      ],
      "default": "EXECUTION_STEP_STATUS_UNSPECIFIED",
      "description": "ExecutionStepStatus represents the lifecycle state of an individual step.\n\n - EXECUTION_STEP_STATUS_PENDING: Step is queued and waiting to start.\n - EXECUTION_STEP_STATUS_RUNNING: Step is actively running.\n - EXECUTION_STEP_STATUS_COMPLETED: Step completed successfully.\n - EXECUTION_STEP_STATUS_FAILED: Step failed with an error.\n - EXECUTION_STEP_STATUS_SKIPPED: Step was skipped due to conditional logic.\n - EXECUTION_STEP_STATUS_WAITING: Step is waiting for an external event (e.g., approval, callback)."
    },
    "v1GetExecutionResponse": {
