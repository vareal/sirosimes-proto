    "v1PageToken": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "Opaque cursor token. Pass to the next request to get the next page.\nEmpty string means \"start from the beginning\"."
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "description": "Number of items to return."
        }
      },
      "description": "PageToken supports cursor-based pagination for large or real-time datasets.\nThe token is opaque to clients — internal structure is service-defined."
    },
    "v1PageTokenResponse": {
      "type": "object",
      "properties": {
        "nextToken": {
          "type": "string",
          "description": "Token for the next page. Empty if no more results."
        },
        "hasMore": {
          "type": "boolean",
          "description": "Whether more results are available."
        }
      },
      "description": "PageTokenResponse is the cursor-based pagination output."
    },
    "v1PaginationRequest": {
      "type": "object",
      "properties": {
        "page": {
          "type": "integer",
          "format": "int32",
          "description": "Page number (1-indexed)."
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "description": "Number of items per page (max enforced per-service)."
        },
        "sortBy": {
          "type": "string",
          "description": "Field name to sort by."
        },
        "sortOrder": {
          "$ref": "#/definitions/v1SortOrder",
          "description": "Sort direction."
        }
      },
      "description": "PaginationRequest is the standard offset-based pagination input."
    },
    "v1PaginationResponse": {
      "type": "object",
      "properties": {
        "page": {
          "type": "integer",
          "format": "int32"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32"
        },
        "totalItems": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of matching items (may be expensive for large datasets)."
        },
        "totalPages": {
          "type": "integer",
          "format": "int32"
        },
        "hasNext": {
          "type": "boolean"
        },
        "hasPrev": {
          "type": "boolean"
        }
      },
      "description": "PaginationResponse is the standard offset-based pagination output."
    },
    "v1SortOrder": {
      "type": "string",
      "enum": [
        "SORT_ORDER_UNSPECIFIED",
        "SORT_ORDER_ASC",
        "SORT_ORDER_DESC"
      ],
      "default": "SORT_ORDER_UNSPECIFIED",
      "description": "SortOrder specifies the sort direction."
    },
