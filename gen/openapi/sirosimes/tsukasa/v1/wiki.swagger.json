    "v1ActorRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/v1ActorType"
        },
        "displayName": {
          "type": "string"
        }
      },
      "description": "ActorRef is a lightweight reference to an Actor (for embedding in other messages).\nUse this instead of full Actor when only identity info is needed (e.g., in audit logs)."
    },
    "v1ActorType": {
      "type": "string",
      "enum": [
        "ACTOR_TYPE_UNSPECIFIED",
        "ACTOR_TYPE_HUMAN",
        "ACTOR_TYPE_AI_EMPLOYEE",
        "ACTOR_TYPE_SYSTEM",
        "ACTOR_TYPE_EXTERNAL_SERVICE"
      ],
      "default": "ACTOR_TYPE_UNSPECIFIED",
      "description": "ActorType classifies the entity performing actions.\n\n - ACTOR_TYPE_HUMAN: A human employee of the Vareal Group.\n - ACTOR_TYPE_AI_EMPLOYEE: An AI employee (e.g., Fujiwara Ai, Stefan Skye).\n - ACTOR_TYPE_SYSTEM: An automated system process (cron, workflow engine, etc.).\n - ACTOR_TYPE_EXTERNAL_SERVICE: An external service or API client."
    },
