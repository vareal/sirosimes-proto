    "v1AlertSeverity": {
      "type": "string",
      "enum": [
        "ALERT_SEVERITY_UNSPECIFIED",
        "ALERT_SEVERITY_INFO",
        "ALERT_SEVERITY_WARNING",
        "ALERT_SEVERITY_HIGH",
        "ALERT_SEVERITY_CRITICAL",
        "ALERT_SEVERITY_EMERGENCY"
      ],
      "default": "ALERT_SEVERITY_UNSPECIFIED",
      "description": "- ALERT_SEVERITY_INFO: 情報（ログ記録のみ）。\n - ALERT_SEVERITY_WARNING: 警告（司チャットで通知）。\n - ALERT_SEVERITY_HIGH: 高（SMS + 司チャットで通知）。\n - ALERT_SEVERITY_CRITICAL: クリティカル（電話 + SMS + 司チャットで通知）。\n - ALERT_SEVERITY_EMERGENCY: 緊急（Video Call + 電話 + SMS + 司チャットで通知）。",
      "title": "AlertSeverity はアラートの深刻度を分類する。\nnotification.proto の通知チャネル選択に直結する。"
    },
