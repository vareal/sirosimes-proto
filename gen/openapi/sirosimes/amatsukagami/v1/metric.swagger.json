      "default": "AGGREGATION_METHOD_UNSPECIFIED",
      "title": "AggregationMethod はメトリクス集約方法を定義する。"
    },
    "v1CollectorSource": {
      "type": "string",
      "enum": [
        "COLLECTOR_SOURCE_UNSPECIFIED",
        "COLLECTOR_SOURCE_OTLP",
        "COLLECTOR_SOURCE_REDIS_STREAM",
        "COLLECTOR_SOURCE_SECURITY_EVENT",
        "COLLECTOR_SOURCE_PROMETHEUS",
        "COLLECTOR_SOURCE_TSUKASA_API",
        "COLLECTOR_SOURCE_HATAORI_EVENT",
        "COLLECTOR_SOURCE_WEBHOOK",
        "COLLECTOR_SOURCE_MANUAL"
      ],
      "default": "COLLECTOR_SOURCE_UNSPECIFIED",
      "description": "- COLLECTOR_SOURCE_OTLP: OpenTelemetry Protocol（gRPC/HTTP）。\n - COLLECTOR_SOURCE_REDIS_STREAM: Redis Streams Consumer。\n - COLLECTOR_SOURCE_SECURITY_EVENT: SecurityEvent（sentinel.proto連携）。\n - COLLECTOR_SOURCE_PROMETHEUS: Prometheus scrape endpoint。\n - COLLECTOR_SOURCE_TSUKASA_API: 司API（社員・タスク・プロジェクトデータ）。\n - COLLECTOR_SOURCE_HATAORI_EVENT: 機織WF実行データ。\n - COLLECTOR_SOURCE_WEBHOOK: 外部Webhook。\n - COLLECTOR_SOURCE_MANUAL: 手動入力。",
      "title": "CollectorSource はメトリクス収集ソースを分類する。"
    },
