          "type": "string",
          "title": "メトリクス名（一意キー）。"
        },
        "description": {
          "type": "string",
          "title": "説明。"
        },
        "type": {
          "$ref": "#/definitions/v1MetricType",
          "title": "メトリクス種別。"
        },
        "domain": {
          "$ref": "#/definitions/v1MonitoringDomain",
          "title": "監視領域。"
        },
        "unit": {
          "type": "string",
          "title": "単位。"
