    },
    "v1MetricType": {
      "type": "string",
      "enum": [
        "METRIC_TYPE_UNSPECIFIED",
        "METRIC_TYPE_COUNTER",
        "METRIC_TYPE_GAUGE",
        "METRIC_TYPE_HISTOGRAM",
        "METRIC_TYPE_SUMMARY",
        "METRIC_TYPE_BOOLEAN"
      ],
      "default": "METRIC_TYPE_UNSPECIFIED",
      "description": "- METRIC_TYPE_COUNTER: カウンター（単調増加値）。\n - METRIC_TYPE_GAUGE: ゲージ（瞬時値）。\n - METRIC_TYPE_HISTOGRAM: ヒストグラム（分布）。\n - METRIC_TYPE_SUMMARY: サマリー（パーセンタイル）。\n - METRIC_TYPE_BOOLEAN: ブーリアン（正常/異常）。",
      "title": "MetricType はメトリクスの種別を分類する。"
    },
    "v1MonitoringDomain": {
      "type": "string",
      "enum": [
        "MONITORING_DOMAIN_UNSPECIFIED",
        "MONITORING_DOMAIN_BUSINESS",
        "MONITORING_DOMAIN_FINANCE",
        "MONITORING_DOMAIN_AI_EMPLOYEE",
        "MONITORING_DOMAIN_PRODUCT",
        "MONITORING_DOMAIN_SECURITY",
        "MONITORING_DOMAIN_INFRASTRUCTURE",
        "MONITORING_DOMAIN_PHYSICAL",
        "MONITORING_DOMAIN_HUMAN_EMPLOYEE"
      ],
      "default": "MONITORING_DOMAIN_UNSPECIFIED",
      "description": "- MONITORING_DOMAIN_BUSINESS: 領域1: ビジネスメトリクス（売上・案件・KPI）。\n - MONITORING_DOMAIN_FINANCE: 領域2: 財務メトリクス（キャッシュフロー・予実・経費）。\n - MONITORING_DOMAIN_AI_EMPLOYEE: 領域3: AI社員メトリクス（稼働・トークン・タスク完了率）。\n - MONITORING_DOMAIN_PRODUCT: 領域4: プロダクトメトリクス（可用性・レイテンシ・エラー率）。\n - MONITORING_DOMAIN_SECURITY: 領域5: セキュリティメトリクス（脅威検知・認証失敗・侵入試行）。\n - MONITORING_DOMAIN_INFRASTRUCTURE: 領域6: インフラメトリクス（CPU・メモリ・ディスク・ネットワーク）。\n - MONITORING_DOMAIN_PHYSICAL: 領域7: 物理世界メトリクス（IoTセンサー・ロボット・環境）。\n - MONITORING_DOMAIN_HUMAN_EMPLOYEE: 領域8: 人間社員メトリクス（勤怠・業務量・デバイス・パフォーマンス）。",
      "title": "MonitoringDomain は監視領域を分類する。"
    },
    "v1PaginationRequest": {
      "type": "object",
