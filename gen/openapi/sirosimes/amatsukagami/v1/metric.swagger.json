      "properties": {
        "integrityValid": {
          "type": "boolean"
        },
        "recordsChecked": {
          "type": "integer",
          "format": "int32"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1IntegrityRecord"
          }
        }
      }
    }
