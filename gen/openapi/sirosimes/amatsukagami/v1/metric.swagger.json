          "type": "string",
          "title": "ソースサービス名。"
        },
        "unit": {
          "type": "string",
          "title": "単位（例: \"percent\", \"bytes\", \"requests/s\", \"yen\"）。"
        }
      },
      "title": "MetricDataPoint は単一のメトリクスデータポイントを表す。"
    },
    "v1MetricDefinition": {
