    "v1ResourceMetadata": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UUID format recommended)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the resource was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last update."
        },
        "deletedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Soft-delete timestamp (null if not deleted).\nFor RESTRICTED resources, see SECURITY.md for physical deletion policy."
        },
        "createdBy": {
          "type": "string",
          "description": "Actor ID who created this resource."
        },
        "updatedBy": {
          "type": "string",
          "description": "Actor ID who last updated this resource."
        },
        "version": {
          "type": "string",
          "format": "int64",
          "description": "Optimistic concurrency version counter."
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Arbitrary key-value labels for filtering and organization."
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Arbitrary key-value annotations for tooling metadata."
        },
        "securityLevel": {
          "$ref": "#/definitions/v1SecurityLevel",
          "description": "Security classification level for this resource (CISO directive).\nDefault when unspecified: treated as INTERNAL."
        }
      },
      "description": "ResourceMetadata provides standard metadata for all Sirosimes resources.\nEvery domain entity across all products should embed this message to ensure\nconsistent tracking, versioning, and security classification.\n\nRelated types:\n  - Actor/ActorRef (actor.proto): created_by/updated_by reference Actor IDs.\n  - AuditLog (audit.proto): changes to resources are tracked via audit events.\n  - SecurityLevel: controls access, encryption, and retention policies.\n\nDefault behavior for security_level:\n  When security_level is UNSPECIFIED (0), domain services SHOULD treat the resource\n  as INTERNAL (level 2) by default. This ensures that resources without explicit\n  classification are not accidentally treated as PUBLIC. Services MAY override this\n  default with stricter levels based on their domain requirements."
    },
    "v1RubricLevel": {
      "type": "string",
      "enum": [
        "RUBRIC_LEVEL_UNSPECIFIED",
        "RUBRIC_LEVEL_L1",
        "RUBRIC_LEVEL_L2",
        "RUBRIC_LEVEL_L3",
        "RUBRIC_LEVEL_L4",
        "RUBRIC_LEVEL_L5"
      ],
      "default": "RUBRIC_LEVEL_UNSPECIFIED",
      "title": "RubricLevel は評価ルーブリックの5段階レベル。"
    },
    "v1SecurityLevel": {
      "type": "string",
      "enum": [
        "SECURITY_LEVEL_UNSPECIFIED",
        "SECURITY_LEVEL_PUBLIC",
        "SECURITY_LEVEL_INTERNAL",
        "SECURITY_LEVEL_CONFIDENTIAL",
        "SECURITY_LEVEL_RESTRICTED"
      ],
      "default": "SECURITY_LEVEL_UNSPECIFIED",
      "description": "SecurityLevel classifies data sensitivity per CISO directive (ISO 27001 aligned).\n\nClassification guide:\n  PUBLIC (1)       — Marketing content, public documentation, open-source code.\n                     Encryption: transit only. Logging: optional. Retention: unlimited.\n  INTERNAL (2)     — Internal wikis, team communications, non-sensitive business data.\n                     Encryption: transit required. Logging: optional. Retention: 3 years.\n  CONFIDENTIAL (3) — Financial reports, HR records, customer data, business strategies.\n                     Encryption: transit + at-rest. Logging: required. Retention: 1 year.\n                     Masking required when exposed externally.\n  RESTRICTED (4)   — PII, credentials, API keys, authentication tokens, audit trails.\n                     Encryption: transit + at-rest + field-level. Logging: required + tamper detection.\n                     Retention: 6 months. Masking: always required.\n\n - SECURITY_LEVEL_PUBLIC: Open data, no access restrictions. Marketing, public docs.\n - SECURITY_LEVEL_INTERNAL: Internal use only. Team wikis, non-sensitive business data.\n - SECURITY_LEVEL_CONFIDENTIAL: Business-sensitive, need-to-know basis. Financial, HR, customer data.\n - SECURITY_LEVEL_RESTRICTED: Highest sensitivity. PII, credentials, tokens, audit trails."
    },
