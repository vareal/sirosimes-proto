    "sirosimestamanoyav1ApprovalStatus": {
      "type": "string",
      "enum": [
        "APPROVAL_STATUS_UNSPECIFIED",
        "APPROVAL_STATUS_PENDING_REVIEW",
        "APPROVAL_STATUS_APPROVED",
        "APPROVAL_STATUS_REJECTED",
        "APPROVAL_STATUS_MODIFIED"
      ],
      "default": "APPROVAL_STATUS_UNSPECIFIED",
      "description": "- APPROVAL_STATUS_PENDING_REVIEW: AI評価完了、人事管理者の承認待ち\n - APPROVAL_STATUS_APPROVED: 人事管理者が承認済み\n - APPROVAL_STATUS_REJECTED: 人事管理者が却下（再評価必要）\n - APPROVAL_STATUS_MODIFIED: 人事管理者が一部変更後承認",
      "title": "ApprovalStatus は承認ワークフローのステータス。"
    },
